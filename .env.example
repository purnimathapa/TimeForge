# Copy this file to .env and adjust values for local development.
# Required variables have no default in settings; missing values raise an error at startup.

# Django core
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Institution timezone (IANA name). Default in settings: Asia/Kathmandu (UTC+5:45).
TIME_ZONE=Asia/Kathmandu

# PostgreSQL (local Postgres.app or Homebrew Postgres on macOS)
DB_NAME=timeforge
DB_USER=your_macos_username
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
